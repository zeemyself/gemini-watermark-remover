{
  "name": "gemini-watermark-remover",
  "description": "Automatically removes watermarks from Gemini AI generated images",
  "version": "1.0.0",
  "author": "journey-ad",
  "sideEffects": false,
  "files": [
    "src/core/",
    "src/sdk/",
    "README.md",
    "README_zh.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/GargantuaX/gemini-watermark-remover.git"
  },
  "license": "MIT",
  "type": "module",
  "types": "./src/sdk/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/sdk/index.d.ts",
      "import": "./src/sdk/index.js"
    },
    "./browser": {
      "types": "./src/sdk/browser.d.ts",
      "import": "./src/sdk/browser.js"
    },
    "./image-data": {
      "types": "./src/sdk/image-data.d.ts",
      "import": "./src/sdk/image-data.js"
    },
    "./node": {
      "types": "./src/sdk/node.d.ts",
      "import": "./src/sdk/node.js"
    }
  },
  "scripts": {
    "dev": "node build.js",
    "build": "node build.js --prod",
    "test": "node --test tests/**/*.test.js",
    "test:sdk-smoke": "node --test tests/sdk/packageMetadata.test.js tests/sdk/packagePack.test.js tests/sdk/typeDeclarations.test.js tests/sdk/consumerRuntime.test.js tests/sdk/typescriptConsumer.test.js tests/sdk/smokeAutomation.test.js",
    "test:extension-smoke": "node --test tests/extension/contentScriptSmoke.test.js",
    "debug:auto": "node scripts/debug-extension.js",
    "debug:auto:clean": "node scripts/debug-extension.js --clean",
    "debug:manual": "cmd /c \"set GWR_DEBUG_BROWSER=native-chrome&& node scripts/debug-extension.js\"",
    "debug:manual:clean": "cmd /c \"set GWR_DEBUG_BROWSER=native-chrome&& node scripts/debug-extension.js --clean\"",
    "debug:chrome": "pnpm debug:auto",
    "debug:chrome:clean": "pnpm debug:auto:clean",
    "serve": "pnpm dlx serve dist",
    "export:samples": "node scripts/export-fixed-samples.js"
  },
  "dependencies": {
    "exifr": "^7.1.3",
    "jszip": "^3.10.1",
    "medium-zoom": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "esbuild": "^0.24.0",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
